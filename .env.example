# === Polymarket Credentials ===
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER=

# === Bankroll ===
BANKROLL_USDC=10.0

# === Endgame Strategy ===
# Buy outcomes priced between 92-98 cents (high probability, near certain)
MIN_ENDGAME_PROB=0.92
MAX_ENDGAME_PRICE=0.98
# Only look at markets resolving within 14 days
MAX_DAYS_TO_RESOLUTION=14
# Skip markets with less than $1000 total volume (too thin)
MIN_MARKET_VOLUME=1000
# Execute only the top 3 opportunities per scan cycle
MAX_TRADES_PER_CYCLE=3

# === Risk Limits (aggressive for $10) ===
# Up to $2 per position (20% of $10)
MAX_POSITION_PCT=20.0
# Up to $8 total exposure (80% of $10)
MAX_TOTAL_EXPOSURE_PCT=80.0
# Kill switch if you lose $3 (30% of $10)
MAX_DRAWDOWN_PCT=30.0

# === Scanning ===
SCAN_INTERVAL_SECONDS=5.0
MARKETS_REFRESH_SECONDS=120.0
# Only scan top 500 markets by volume (faster cycles)
MAX_MARKETS=500
TICK_SIZE=0.01

# === Rust Arb Engine ===
# Minimum spread (YES ask + NO ask < $1.00) as percentage
ARB_MIN_SPREAD_PCT=0.5
# Max spend per arb trade
ARB_MAX_POSITION_USDC=2.0
# Max total arb exposure
ARB_MAX_EXPOSURE_USDC=8.0

# === Safety ===
# ALWAYS start with true. Only set false when you're ready to trade real money.
DRY_RUN=true
